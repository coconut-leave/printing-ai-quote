# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/printing_ai_quote"

# OpenAI API key used by the quote extraction flow
# Replace the placeholder before any deploy or trial rehearsal.
OPENAI_API_KEY="sk-..."

# Minimal admin protection secret for internal pages and admin APIs
# Trial / production should set a strong value with at least 12 characters.
# Do not keep the placeholder or other weak defaults in any deploy environment.
ADMIN_SECRET="change-this-admin-secret"

# Optional runtime port for npm start / next start
PORT="3000"

# Keep empty in normal production operation.
# Trial / production must keep this empty.
# Only set to true for explicit one-time seed actions.
ALLOW_SEED=""